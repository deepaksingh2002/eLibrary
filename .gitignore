# Root-level gitignore for eLibrary

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js
.next/
.out/
build/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Mac
.AppleDouble
.LSOverride

# Coverage
coverage/
.nyc_output/

# Test output
/jest

# Static analysis
.eslintcache

# Temporary
.cache/
.tmp/

# Vercel / hosting
.vercel/

# Build artifacts
dist/
build/

# Misc
*.pem
*.key
*.crt

# PDF.js build artifacts (if present)
pdfjs-dist/

# Ignore client and server specific build dirs if present
/client/.next/
/server/.next/

# Ignore IDE-specific workspace files
*.code-workspace

# Local secrets
secrets.env

# End of .gitignore
