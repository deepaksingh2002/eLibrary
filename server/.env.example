PORT=5000
NODE_ENV=development
ADMIN_EMAIL=admin@elibrary.local
ADMIN_PASSWORD=Admin@12345
MONGO_URI=
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Comma-separated list of allowed CORS origins for the API (preferred).
# Example: CORS_ORIGINS=http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000

# FRONTEND_URL may be used to build links in emails (optional).
FRONTEND_URL=http://localhost:3000
OPENAI_API_KEY=
OPENAI_MODEL=
# Optional OpenAI embedding model for vector generation.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional Redis URL for queue/caching.
REDIS_URL=redis://127.0.0.1:6379
# Optional legacy Redis alias (REDIS_URL is preferred).
REDIS=

# Optional PDF/OCR tuning values.
PDF_OCR_DPI=220
PDF_OCR_LANG=eng
PDF_TEXT_MIN_WORDS=120
PDF_TEXT_MIN_PAGE_WORDS=18

CRON_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="eLibrary <noreply@elibrary.app>"
PASSWORD_RESET_EXPIRES_MINUTES=30
